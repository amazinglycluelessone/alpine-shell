<?xml version="1.0" encoding="utf-8"?>
<!-- Simple terminal > prompt icon for the notification bar -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Outer rectangle representing a terminal window -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:pathData="M3,4 L21,4 L21,20 L3,20 Z" />
    <!-- > prompt chevron -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M6,9 L10,12 L6,15" />
    <!-- cursor underscore -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.8"
        android:strokeLineCap="round"
        android:pathData="M12,15 L18,15" />
</vector>
